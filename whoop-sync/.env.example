# ── WHOOP Developer App ──────────────────────────────────────────
# Copia estos valores desde https://developer-dashboard.whoop.com
WHOOP_CLIENT_ID=your-client-id-here
WHOOP_CLIENT_SECRET=your-client-secret-here

# ── Firebase ─────────────────────────────────────────────────────
# Proyecto Firebase (ya configurado en la web app)
FIREBASE_PROJECT_ID=gym-tracker-at

# Ruta al JSON de la cuenta de servicio que descargas desde:
# Firebase Console → Project Settings → Service Accounts → Generate new private key
FIREBASE_SERVICE_ACCOUNT=./firebase-service-account.json

# ── Tu UID de Firebase ───────────────────────────────────────────
# Encuéntralo en Firebase Console → Authentication → Users
# o en la web app: abre DevTools → Console → escribe: firebase.auth().currentUser.uid
FIREBASE_USER_UID=your-firebase-uid-here

# ── Opciones de sync ─────────────────────────────────────────────
# Cuántos días hacia atrás sincronizar workouts (por defecto 7)
SYNC_DAYS_BACK=7
